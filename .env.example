# ── peikonpurekkusu environment ──────────────────────────────────────────────
# Copy to .env (make up does this automatically) and adjust as needed.
# Every value here is a DEV default — never reuse these in any shared environment.

# ── Edge ─────────────────────────────────────────────────────────────────────
# Host port Traefik binds (80 may be taken by other local stacks)
HTTP_PORT=9080
APP_HOST=app.localhost
API_HOST=api.localhost
TRAEFIK_DASHBOARD_HOST=traefik.localhost
# htpasswd hash for the Traefik dashboard (dev default: admin / peikon-dev)
# generate: htpasswd -nB admin | sed -e 's/\$/\$\$/g'  (escape $ as $$ for compose)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$ig4Ek5Mc$$UYmea/BtIkzECIpTibxcZ0

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:19092
KAFKA_CLUSTER_ID=peikon-kraft-cluster-01

# ── PostgreSQL (database per service) ────────────────────────────────────────
USERS_DB_USER=users_svc
USERS_DB_PASSWORD=users-dev-pw
USERS_DB_NAME=users

ACCOUNT_DB_USER=account_svc
ACCOUNT_DB_PASSWORD=account-dev-pw
ACCOUNT_DB_NAME=accounts

PAYMENT_DB_USER=payment_svc
PAYMENT_DB_PASSWORD=payment-dev-pw
PAYMENT_DB_NAME=payments

TRANSACTION_DB_USER=transaction_svc
TRANSACTION_DB_PASSWORD=transaction-dev-pw
TRANSACTION_DB_NAME=transactions

FRAUD_DB_USER=fraud_svc
FRAUD_DB_PASSWORD=fraud-dev-pw
FRAUD_DB_NAME=fraud

NOTIFICATION_DB_USER=notification_svc
NOTIFICATION_DB_PASSWORD=notification-dev-pw
NOTIFICATION_DB_NAME=notifications

# ── Redis (two instances: eviction policies conflict) ───────────────────────
REDIS_SESSION_PASSWORD=redis-session-dev-pw
REDIS_CACHE_PASSWORD=redis-cache-dev-pw

# ── Audit sink ───────────────────────────────────────────────────────────────
# AUDIT_SINK=postgres (default): append-only partitioned table in audit-db.
# AUDIT_SINK=cassandra: needs ~2 GB free in the Docker VM;
#   start the stack with COMPOSE_PROFILES=cassandra make up
AUDIT_SINK=postgres
CASSANDRA_CLUSTER_NAME=peikon-audit
AUDIT_DB_USER=audit_svc
AUDIT_DB_PASSWORD=audit-dev-pw
AUDIT_DB_NAME=audit

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_ISSUER=https://api.localhost/auth
JWT_AUDIENCE=peikonpurekkusu
# seconds (10 min)
ACCESS_TOKEN_TTL=600
# seconds (14 days)
REFRESH_TOKEN_TTL=1209600
# seconds — internal gateway assertion lifetime (short: expiry bounds replay on the internal net)
GATEWAY_ASSERTION_TTL=60
# ES256 signing keys are generated into ./secrets/ by `make up` (never committed)

# ── Mock PSP behavior ────────────────────────────────────────────────────────
MOCK_PSP_LATENCY_MS=120
# transient 5xx rate (exercises retry + breaker)
MOCK_PSP_FAILURE_RATE=0.05
# Declines are deterministic, not rate-driven: an amount ending in ...42 is hard
# declined and ...13 raises a transient error, so tests can force either outcome.

# ── Observability (profile: observability) ──────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# flipped to false when the profile is active
OTEL_SDK_DISABLED=true

# ── Cookies (dev: plain HTTP → no Secure/prefixes; production: __Host-at / __Secure-rt / true)
COOKIE_ACCESS_NAME=at
COOKIE_REFRESH_NAME=rt
COOKIE_SECURE=false
